{
  "manifest_version": 3,
  "name": "ezXSave",
  "version": "2.0",
  "description": "Download X videos with highest quality via Syndication API",
  "permissions": ["downloads", "contextMenus"],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://cdn.syndication.twimg.com/*",
    "https://video.twimg.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["content.js"],
      "css": ["style.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}